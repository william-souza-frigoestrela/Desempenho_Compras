		sortByColumn: Mes

		annotation SummarizationSetBy = Automatic

	partition Calendario = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(
				        DATE(2023,1,1),          -- data inicial
				        DATE(2099,12,31)         -- data final (ajuste conforme sua base)
				    ),
				    "Ano", YEAR([Date]),
				    "Mes", MONTH([Date]),
				    "NomeMes", FORMAT([Date], "mmmm"),
				    "AnoMes", FORMAT([Date], "YYYY-MM"),
				    "Dia", DAY([Date]),
				    "DiaSemana", WEEKDAY([Date], 2),           -- 2 = segunda como primeiro dia da semana
				    "NomeDiaSemana", FORMAT([Date], "dddd")
				)

	annotation PBI_Id = 5a4c8df1ccf2429f8fbbd1da0ed58ecf

