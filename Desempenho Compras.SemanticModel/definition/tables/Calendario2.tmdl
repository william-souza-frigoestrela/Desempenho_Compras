	column nomeMES/ano = ```
			Calendario2[Ano] & "/"& Calendario2[NomeMes] 
			```
		lineageTag: 014a7dac-1138-4558-a52a-e9e7df1a762d
		summarizeBy: none
		sortByColumn: AnoMes

		annotation SummarizationSetBy = Automatic

	partition Calendario2 = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(
				        DATE(2025,1,1),          -- data inicial
				        DATE(2026,12,31)         -- data final (ajuste conforme sua base)
				    ),
				    "Ano", YEAR([Date]),
				    "Mes", MONTH([Date]),
				    "NomeMes", FORMAT([Date], "mmmm"),
				    "AnoMes", FORMAT([Date], "YYYY-MM"),
				    "Dia", DAY([Date]),
				    "DiaSemana", WEEKDAY([Date], 2),           -- 2 = segunda como primeiro dia da semana
				    "NomeDiaSemana", FORMAT([Date], "dddd")
				)

	annotation PBI_Id = 681c63e207e541938b2fe6292d7d9ba4

