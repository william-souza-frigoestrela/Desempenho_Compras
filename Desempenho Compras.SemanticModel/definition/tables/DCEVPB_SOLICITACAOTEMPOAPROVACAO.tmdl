	column Tempo_Fechamento_Horas =
			
			VAR inicio = 'DCEVPB_SOLICITACAOTEMPOAPROVACAO'[SOLIAPROVACAO]
			VAR fim = 'DCEVPB_SOLICITACAOTEMPOAPROVACAO'[DATAHORAPEDIDO]
			RETURN
			IF(
			    ISBLANK(inicio) || ISBLANK(fim),
			    BLANK(),
			    IF(
			        fim >= inicio,
			        DIVIDE(DATEDIFF(inicio, fim, MINUTE), 60.0),
			        BLANK()   -- evita valores negativos se a data estiver invertida
			    )
			)
		formatString: 0
		lineageTag: bb085e5b-5930-43e9-aeed-66f90f445847
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

