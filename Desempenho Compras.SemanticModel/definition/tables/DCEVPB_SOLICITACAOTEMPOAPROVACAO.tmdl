	column 'Status Solicitação' = ```
			
			var vr1 = 
			SWITCH(DCEVPB_SOLICITACAOTEMPOAPROVACAO[STATUS],
			3, "SOLICITAÇÃO APROVADA",
			4, "COTAÇÃO PRÉ-APROVADA",
			5, "COTAÇÃO APROVADA"
			)
			
			var vr2 = "SIMPLIFICADA"
			
			RETURN 
			
			IF(DCEVPB_SOLICITACAOTEMPOAPROVACAO[NOME] = "SOLICITAÇÃO SIMPLIFICADA",vr2,VR1)
			```
