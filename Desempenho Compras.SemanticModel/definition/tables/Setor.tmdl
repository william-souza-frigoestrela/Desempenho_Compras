	partition Setor = m
		mode: import
		source =
				let
				    Fonte = Oracle.Database("TOTVS_RM", [HierarchicalNavigation=true, Query="SELECT E.SEQPESSOADTV,D.DEPARTAMENTO,D.SETOR#(lf)  FROM EST_DEPARAPESSOA E#(lf)  LEFT JOIN PFUNC F#(lf)    ON E.CODCOLIGADA = F.CODCOLIGADA#(lf)   AND E.CHAPA = F.CHAPA#(lf)  LEFT JOIN FPBI_DEPARTAMENTO D#(lf)  ON F.CODSECAO = D.CODIGO#(lf)"])
				in
				    Fonte

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegação

