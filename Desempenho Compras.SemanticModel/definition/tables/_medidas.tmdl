	measure 'Gasto Acumulado Produto' =
			
			VAR RankAtual = [Rank Produto]
			RETURN
			CALCULATE(
			    [_somaVlrCompra],
			    FILTER(
			        ALLSELECTED(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SUBGRUPO]),
			        [Rank Produto] <= RankAtual
