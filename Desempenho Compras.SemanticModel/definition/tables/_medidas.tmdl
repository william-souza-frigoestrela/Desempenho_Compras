	measure 'Eficiência ( itensSolicitados vs itensEntregues)' = ```
			
			
			var vr1 = [Itens com Pedido (Período Pedido)] 
			VAR Vr2 = [Itens Solicitados no Período]
			RETURN
			IF(vr1 = 0 && Vr2 > 0, 0,
			DIVIDE(vr1,Vr2,1))
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: _TelaEficiencia
