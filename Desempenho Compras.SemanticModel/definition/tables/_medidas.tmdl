table _medidas
	lineageTag: e1d7000b-cac9-4a31-ab0e-01c5625b3468

	measure 'Pedidos Gerados no Período' =
			CALCULATE(DISTINCTCOUNT(DCEVPB_SOLICITACAOTEMPOAPROVACAO[Pk Pedido]),
			DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] >= MIN(Calendario2[Date]) && DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAEMISSAO] <= MAX(Calendario2[Date]))
		formatString: #,0
		displayFolder: _TelaEficiencia
		lineageTag: 32d5a226-6a83-4590-85b1-6be7c9dc7280

	measure 'Solicitações em Aberto' =
			
			
			CALCULATE(DISTINCTCOUNT(DCEVPB_SOLICITACAOTEMPOAPROVACAO[PK]), DCEVPB_SOLICITACAOTEMPOAPROVACAO[STATUS] >=3 && DCEVPB_SOLICITACAOTEMPOAPROVACAO[STATUS] <=4)
		formatString: #,0
		displayFolder: _TelaEficiencia
		lineageTag: 17a4f9ef-eec0-41be-b0cf-1322bf9a2add

	measure 'Solicitações Criadas no Período' =
			
			
			CALCULATE(DISTINCTCOUNT(DCEVPB_SOLICITACAOTEMPOAPROVACAO[PK]),
			 DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTASOLICITACAO] >= MIN(Calendario2[Date]) &&
			DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTASOLICITACAO] <= MAX(Calendario2[Date])
			
			)
		formatString: #,0
		displayFolder: _TelaEficiencia
		lineageTag: 271d86aa-a3a8-4b15-a636-d7179abb0b01

	measure 'Tempo Médio (Aprovação x Pedido)' =
			
			
			VAR TempoMedioDias =
			    AVERAGEX(
			        FILTER(
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO,
			            NOT(ISBLANK(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DATAHORAPEDIDO])) &&
			            NOT(ISBLANK(DCEVPB_SOLICITACAOTEMPOAPROVACAO[SOLIAPROVACAO])) &&
			            DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAAPROVACAOPEDIDO] >= MIN(Calendario2[Date]) && DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTAAPROVACAOPEDIDO] <= MAX(Calendario2[Date])
			        ),
			        DCEVPB_SOLICITACAOTEMPOAPROVACAO[DATAHORAPEDIDO] - DCEVPB_SOLICITACAOTEMPOAPROVACAO[SOLIAPROVACAO]
			    )
			VAR Dias = INT(TempoMedioDias)
			VAR Horas = INT(MOD(TempoMedioDias * 24, 24))
			VAR Minutos = INT(MOD(TempoMedioDias * 24 * 60, 60))
			RETURN
			IF([Pedidos Gerados no Período] < 1 , BLANK(),
			
			FORMAT(Dias, "00") & "D " &
			FORMAT(Horas, "00") & "H " &
			FORMAT(Minutos, "00"&"M "))
		displayFolder: _TelaEficiencia
		lineageTag: cd433404-c699-46ee-b8ae-6a4edd6c65bd

	measure 'Solicitação Mais Antiga' = CALCULATE(min(DCEVPB_SOLICITACAOTEMPOAPROVACAO[DTASOLICITACAO]), DCEVPB_SOLICITACAOTEMPOAPROVACAO[STATUS] >=3 && DCEVPB_SOLICITACAOTEMPOAPROVACAO[STATUS] <=4)
		formatString: Short Date
		displayFolder: _TelaEficiencia
		lineageTag: a6ae7f1b-759e-4579-b95e-f3f2854f2e67

	measure 'Qtd Pedidos Sem Entrega Realizada' = CALCULATE(DISTINCTCOUNT(DCEVPB_SOLICITACAOTEMPOAPROVACAO[Pk Pedido]), DCEVPB_SOLICITACAOTEMPOAPROVACAO[NRONOTAFISCAL] = BLANK())
		formatString: #,0
