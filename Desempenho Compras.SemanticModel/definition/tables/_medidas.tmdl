	measure _somaVlrCompra =
			CALCULATE(SUM(DCEVPB_SOLICITACAOTEMPOAPROVACAO[VLRPRODUTOTOTAL]), DCEVPB_SOLICITACAOTEMPOAPROVACAO[NROPEDIDO] <> BLANK())
			//soma o valor total dos pedidos que temos com o fornecedor
		formatString: "R$"#,0.00;-"R$"#,0.00;"R$"#,0.00
		displayFolder: pareto
		lineageTag: af75348d-626c-43e0-8853-a51db547bd55

		annotation PBI_FormatHint = {"currencyCulture":"es-BR"}

	measure o_RankingCategorias =
			
			RANKX(
			    ALLSELECTED(DCEVPB_SOLICITACAOTEMPOAPROVACAO[seqNomeForn]), [_somaVlrCompra]
			)
			
			//Cria um ranking para os fornecedores de acordo com o valor total comprado com eles. (fornecedores que mais gastamos)
		formatString: 0
		displayFolder: pareto
		lineageTag: 7b4a7907-34cc-4fa3-be55-6cd809994144

	measure _somaAcumulada =
			
			CALCULATE(
			    [_somaVlrCompra],
			    TOPN(
			        [o_RankingCategorias],
			        ALL( DCEVPB_SOLICITACAOTEMPOAPROVACAO[seqNomeForn] ),
			        [_somaVlrCompra],
			        DESC
			    )
			)
		formatString: "R$"#,0.00;-"R$"#,0.00;"R$"#,0.00
		displayFolder: pareto
		lineageTag: 37301b31-e663-4384-9270-fadc8321f91d

		annotation PBI_FormatHint = {"currencyCulture":"es-BR"}

	measure _percentualAcumulado = [_somaAcumulada]/CALCULATE([_somaVlrCompra],ALL(DCEVPB_SOLICITACAOTEMPOAPROVACAO[seqNomeForn]))
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: pareto
		lineageTag: 2e6976b0-dd03-4b7c-b8a6-b69a49785f18

	measure 'ABC Fornecedor (por gasto)' =
			
			VAR PercAcum = [_percentualAcumulado]
			RETURN
			SWITCH(
			    TRUE(),
			    PercAcum <= 0.8, "Classe A",
			    PercAcum <= 0.95, "Classe B",
			    "Classe C"
			)
		displayFolder: pareto
		lineageTag: 51f18ee6-d4ab-45fe-a8e0-e8d7a1a99576

	measure 'Cor ABC' =
			
